{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "schemaVersion": 39,
  "tags": ["sagewai"],
  "templating": {"list": [
    {
      "name": "project",
      "label": "Project",
      "type": "custom",
      "query": "global,all",
      "current": {"text": "all", "value": "all"},
      "options": [
        {"text": "All Projects", "value": "all", "selected": true},
        {"text": "Global Only", "value": "global", "selected": false}
      ],
      "includeAll": false
    }
  ]},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Sagewai Admin",
  "uid": "sagewai-overview",
  "panels": [

    {"type": "row", "title": "System Health", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false, "panels": []},

    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"sagewai-admin\"}[5m]))", "legendFormat": "req/s"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}}
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum(rate(http_server_duration_milliseconds_count{service_name=\"sagewai-admin\",http_status_code=~\"5..\"}[5m])) or vector(0)", "legendFormat": "5xx/s"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}}}
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum(http_server_active_requests{service_name=\"sagewai-admin\"})", "legendFormat": "active"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}, {"color": "yellow", "value": 10}]}}}
    },
    {
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "rate(http_server_duration_milliseconds_sum{service_name=\"sagewai-admin\"}[5m]) / rate(http_server_duration_milliseconds_count{service_name=\"sagewai-admin\"}[5m])", "legendFormat": "avg"}],
      "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
    },

    {"type": "row", "title": "HTTP Performance", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "collapsed": false, "panels": []},

    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{service_name=\"sagewai-admin\",http_target!~\"/api/v1/health/.*\"}[5m]))", "legendFormat": "{{http_target}}"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 15, "stacking": {"mode": "normal"}}}}
    },
    {
      "title": "P95 Latency by Route (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket{service_name=\"sagewai-admin\",http_target!~\"/api/v1/health/.*\"}[5m])))", "legendFormat": "{{http_target}}"}],
      "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "fillOpacity": 10}}}
    },

    {"type": "row", "title": "Requests by Status", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}, "collapsed": false, "panels": []},

    {
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 15},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count{service_name=\"sagewai-admin\"}[5m]))", "legendFormat": "{{http_status_code}}"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "bars", "fillOpacity": 60}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "401"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "404"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "500"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]}
    },
    {
      "title": "Response Size (p95)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 15},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_response_size_bytes_bucket{service_name=\"sagewai-admin\"}[5m])))", "legendFormat": "p95 bytes"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "fillOpacity": 10}}}
    },

    {"type": "row", "title": "OTel Pipeline Health", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22}, "collapsed": false, "panels": []},

    {
      "title": "Spans Processed",
      "type": "stat",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 23},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum(otel_sdk_span_started_total{service_name=\"sagewai-admin\"}) or vector(0)", "legendFormat": "spans"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "title": "Log Records Sent",
      "type": "stat",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 23},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "sum(otel_sdk_log_created_total{service_name=\"sagewai-admin\"}) or vector(0)", "legendFormat": "logs"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}}
    },
    {
      "title": "Log Queue Size",
      "type": "timeseries",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 23},
      "datasource": {"type": "prometheus", "uid": "sagewai-vm"},
      "targets": [{"expr": "otel_sdk_processor_log_queue_size{service_name=\"sagewai-admin\"}", "legendFormat": "queue"}],
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 20}}}
    },

    {"type": "row", "title": "Application Logs", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28}, "collapsed": false, "panels": []},

    {
      "title": "Logs (filter by project_id in query)",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 29},
      "datasource": {"type": "victoriametrics-logs-datasource", "uid": "sagewai-vl"},
      "targets": [{"expr": "service.name:\"sagewai-admin\"", "refId": "A"}],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showLabels": true,
        "showCommonLabels": false,
        "dedupStrategy": "none"
      },
      "description": "Filter by project: change query to include sagewai.project_id:\"your-slug\". Labels visible in log details."
    }
  ]
}
