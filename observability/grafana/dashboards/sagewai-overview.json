{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{service_namespace=\"sagewai\"}[5m])",
          "legendFormat": "{{http_route}} {{http_method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "HTTP Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket{service_namespace=\"sagewai\"}[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_namespace=\"sagewai\",http_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(http_server_active_requests{service_namespace=\"sagewai\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "" },
      "targets": [
        {
          "expr": "*",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sagewai"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Sagewai Overview",
  "uid": "sagewai-overview"
}
