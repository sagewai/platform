{
  "scopeName": "source.sagewai-directives",
  "patterns": [
    {
      "name": "entity.name.tag.sagewai.context",
      "match": "@context\\([^)]*\\)"
    },
    {
      "name": "entity.name.tag.sagewai.memory",
      "match": "@memory\\([^)]*\\)"
    },
    {
      "name": "entity.name.tag.sagewai.agent",
      "match": "@agent:[a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)"
    },
    {
      "name": "entity.name.tag.sagewai.workflow",
      "match": "@wf:[a-zA-Z_][a-zA-Z0-9_]*\\([^)]*\\)"
    },
    {
      "name": "entity.name.function.sagewai.tool",
      "match": "/[a-zA-Z_][a-zA-Z0-9_.]*\\([^)]*\\)"
    },
    {
      "name": "keyword.control.sagewai.meta",
      "match": "#(model|budget|temperature|max_tokens):[^\\s]+"
    },
    {
      "name": "variable.other.sagewai.dynamic",
      "match": "@(datetime|date|time|user|project)"
    },
    {
      "name": "meta.embedded.sagewai.template",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "patterns": [
        {
          "name": "entity.name.function.sagewai.template-call",
          "match": "context\\.search|memory\\.search|agent\\.run"
        }
      ]
    }
  ]
}
