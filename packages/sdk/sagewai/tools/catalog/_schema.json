{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sagewai.ai/schemas/tool-catalog-entry.json",
  "title": "Sagewai tool catalog entry",
  "type": "object",
  "required": ["id", "version", "title", "description", "category", "kind", "sandbox_tier", "exec", "scopes", "setup"],
  "additionalProperties": false,
  "properties": {
    "id":          { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "version":     { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "title":       { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category":    { "type": "string", "minLength": 1 },
    "kind":        { "enum": ["sdk", "http", "mcp", "cli", "webhook", "coap", "modbus", "opcua"] },
    "sandbox_tier":{ "enum": ["TRUSTED", "SANDBOXED", "UNTRUSTED"] },
    "scopes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_]+(\\.[a-z0-9_]+)+$" }
    },
    "exec": { "type": "object" },
    "schemas": { "type": "object" },
    "setup": {
      "type": "object",
      "required": ["auth_complexity", "body"],
      "additionalProperties": true,
      "properties": {
        "auth_complexity": { "enum": ["none", "api_key", "oauth2", "oauth2_webhook", "connection_ref"] },
        "signup_url":      { "type": "string", "format": "uri" },
        "console_path":    { "type": "string" },
        "key_format":      { "type": "string" },
        "required_scopes": { "type": "array", "items": { "type": "string" } },
        "oauth_provider":  { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "test_endpoint":   { "type": "object" },
        "body":            { "type": "string" },
        "credential_fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "label", "type"],
            "additionalProperties": false,
            "properties": {
              "name":        { "type": "string", "minLength": 1 },
              "label":       { "type": "string", "minLength": 1 },
              "type":        { "enum": ["password", "text"] },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "sdk" } } },
      "then": { "properties": { "exec": { "required": ["sdk"], "properties": {
        "sdk": { "type": "object", "required": ["entrypoint"],
                 "properties": { "entrypoint": { "type": "string", "pattern": "^[a-zA-Z0-9_.]+:[a-zA-Z0-9_]+$" } },
                 "additionalProperties": false }
      }, "not": { "anyOf": [
        {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "http" } } },
      "then": { "properties": { "exec": { "required": ["http"], "properties": {
        "http": { "type": "object", "required": ["base_url", "auth", "operations"],
                  "properties": {
                    "base_url": { "type": "string", "format": "uri" },
                    "runtime_base_url_field": { "type": "string" },
                    "auth": { "type": "object", "required": ["kind"],
                              "properties": {
                                "kind": { "enum": ["none", "api_key", "bearer", "basic", "oauth2", "hmac", "aws_sigv4"] },
                                "oauth_provider": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
                              } },
                    "operations": {
                      "type": "object",
                      "minProperties": 1,
                      "additionalProperties": {
                        "type": "object",
                        "required": ["method", "path"],
                        "additionalProperties": true,
                        "properties": {
                          "method":        { "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"] },
                          "path":          { "type": "string" },
                          "body_format":   { "enum": ["form", "json"] },
                          "input_schema":  { "type": "object" },
                          "output_schema": { "type": "object" }
                        }
                      }
                    }
                  }, "additionalProperties": true }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "mcp" } } },
      "then": { "properties": { "exec": { "required": ["mcp"], "properties": {
        "mcp": { "type": "object", "required": ["server_ref"],
                 "properties": { "server_ref": { "type": "string" }, "tool_name": { "type": "string" } } }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "cli" } } },
      "then": { "properties": { "exec": { "required": ["cli"], "properties": {
        "cli": { "type": "object", "required": ["binary", "argv_template"],
                 "properties": { "binary": { "type": "string" }, "argv_template": { "type": "array", "items": { "type": "string" } } } }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "webhook" } } },
      "then": { "properties": { "exec": { "required": ["webhook"], "properties": {
        "webhook": { "type": "object", "required": ["url"],
                     "properties": { "url": { "type": "string", "format": "uri" }, "callback_topic": { "type": "string" } } }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["coap"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "coap" } } },
      "then": { "properties": { "exec": { "required": ["coap"], "properties": {
        "coap": { "type": "object", "required": ["connection_ref", "operation"],
                  "properties": {
                    "connection_ref": { "type": "string", "minLength": 1 },
                    "operation":      { "enum": ["get", "post", "put", "delete"] },
                    "args":           { "type": "object" }
                  },
                  "additionalProperties": false }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["modbus"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "modbus" } } },
      "then": { "properties": { "exec": { "required": ["modbus"], "properties": {
        "modbus": { "type": "object", "required": ["connection_ref", "operation"],
                    "properties": {
                      "connection_ref": { "type": "string", "minLength": 1 },
                      "operation":      { "enum": [
                        "read_coils", "read_discrete_inputs",
                        "read_holding_registers", "read_input_registers",
                        "write_single_coil", "write_single_register",
                        "write_multiple_coils", "write_multiple_registers"
                      ] },
                      "args":           { "type": "object" }
                    },
                    "additionalProperties": false }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["opcua"]}
      ]} } } }
    },
    {
      "if": { "properties": { "kind": { "const": "opcua" } } },
      "then": { "properties": { "exec": { "required": ["opcua"], "properties": {
        "opcua": { "type": "object", "required": ["connection_ref", "operation"],
                   "properties": {
                     "connection_ref": { "type": "string", "minLength": 1 },
                     "operation":      { "type": "string", "minLength": 1 },
                     "args":           { "type": "object" }
                   },
                   "additionalProperties": false }
      }, "not": { "anyOf": [
        {"required": ["sdk"]}, {"required": ["http"]}, {"required": ["mcp"]}, {"required": ["cli"]}, {"required": ["webhook"]}, {"required": ["coap"]}, {"required": ["modbus"]}
      ]} } } }
    },
    {
      "if": { "properties": { "setup": { "properties": { "auth_complexity": { "const": "oauth2" } }, "required": ["auth_complexity"] } } },
      "then": { "properties": { "setup": {
        "required": ["oauth_provider", "required_scopes"],
        "properties": {
          "required_scopes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      } } }
    }
  ]
}
