# Shared build-time constants for all sandbox-<variant> Dockerfiles.
# Bumped quarterly. All variants inherit these via `docker build --build-arg`.

# Debian snapshot date — reproducibly resolves apt packages.
# Latest: https://snapshot.debian.org/
SNAPSHOT_DATE=20260415T000000Z

# python:3.12-slim-bookworm digest pinned to an immutable manifest.
# Look up with: docker buildx imagetools inspect python:3.12-slim-bookworm --format '{{.Manifest.Digest}}'
PYTHON_DIGEST=sha256:58525e1a8dada8e72d6f8a11a0ddff8d981fd888549108db52455d577f927f77
